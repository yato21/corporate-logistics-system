# Основной домен
DOMAIN=yourdomain.com

# Порты сервисов
CLIENT_PORT=3000
SERVER_PORT=5000

# Настройки для сервера
CLIENT_URL=http://${DOMAIN}
PORT=5000
NODE_ENV=production

# Настройки базы данных
DB_HOST=postgres
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=transport_management

# JWT секрет
JWT_SECRET=yoursecretkey 